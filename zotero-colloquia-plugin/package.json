{
  "name": "zotero-colloquia-plugin",
  "type": "module",
  "version": "0.1.0",
  "description": "Colloquia — Voice-powered AI research assistant for Zotero",
  "config": {
    "addonName": "Colloquia",
    "addonID": "colloquia@colloquia.dev",
    "addonRef": "colloquia",
    "addonInstance": "Colloquia",
    "prefsPrefix": "extensions.zotero.colloquia"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kartikmandar/colloquia.git"
  },
  "author": "kartikmandar",
  "homepage": "https://github.com/kartikmandar/colloquia#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4",
    "prettier": "^3.7.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf"
  }
}
